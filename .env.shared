# FRS — SHARED-INFRA env. Points at the shared `vizor-infra` services by their
# container hostnames. Isolation from other scenarios: own DATABASE (frs), own
# Redis DB-number (0), own S3 bucket (vizor-frs), own Qdrant collections
# (app-named: vizor_frs_faces / vizor_frs_faces_snapshots). Creds MUST match
# vizor-infra/.env.
POSTGRES_USER=vizor
POSTGRES_PASSWORD=vizor
POSTGRES_DB=frs
VE_ENV=dev

# Shared backing services (hostnames = vizor-infra container names).
VE_DATABASE_URL=postgresql+asyncpg://vizor:vizor@vizor-postgres:5432/frs
VE_REDIS_URL=redis://vizor-redis:6379/0
VE_QDRANT_URL=http://vizor-qdrant:6333
VE_MEDIAMTX_URL=http://vizor-mediamtx:9997
VE_MEDIAMTX_PUBLIC_HOST=localhost

# Inference backend: 'triton' → shared GPU Triton server (production, batched);
# anything else → in-process edge CPU FaceEngine (dev fallback).
VE_INFERENCE_BACKEND=triton
VE_TRITON_URL=vizor-triton:8000
VE_TRITON_HAS_ANTISPOOF=true

VE_INFERENCE_DEVICE=cpu
VE_JWT_SECRET=change-me-to-a-long-random-string-min-32-bytes
VE_SECRETS_KEY=change-me-another-long-random-string
VE_BOOTSTRAP_ADMIN_EMAIL=support@geniusvision.in
VE_BOOTSTRAP_ADMIN_PASSWORD=Gvd@6001
VE_LICENSE_PUBLIC_KEY_FILE=license_pub.pem
VE_CORS_ORIGINS=["http://localhost:3000"]

# Biometric media stays encrypted at rest (frs/ prefix) even on shared S3.
VE_ENCRYPT_MEDIA_PREFIXES=["frs/"]

# Shared object storage — one RustFS bucket per scenario (auto-created on first write).
VE_STORAGE_BACKEND=s3
VE_S3_ENDPOINT=http://vizor-rustfs:9000
VE_S3_PUBLIC_ENDPOINT=http://localhost:9000
VE_S3_REGION=us-east-1
VE_S3_BUCKET=vizor-frs
VE_S3_ACCESS_KEY=rustfsadmin
VE_S3_SECRET_KEY=rustfsadmin
