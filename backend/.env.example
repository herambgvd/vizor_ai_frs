# Copy to .env. FRS backend config (VE_ prefix → edge.core.config.Settings).

# --- Postgres (image + app URL) ---
POSTGRES_USER=vizor
POSTGRES_PASSWORD=vizor
POSTGRES_DB=frs

# --- App ---
VE_ENV=dev
VE_DATABASE_URL=postgresql+asyncpg://vizor:vizor@postgres:5432/frs
VE_REDIS_URL=redis://redis:6379/0
VE_QDRANT_URL=http://qdrant:6333
VE_MEDIAMTX_URL=http://mediamtx:9997

# Face inference device: "cpu" (default) or "cuda" (NVIDIA GPU). The GPU compose
# override (docker-compose.gpu.yml) sets this to "cuda" automatically.
VE_INFERENCE_DEVICE=cpu

# Secrets — CHANGE in production.
VE_JWT_SECRET=change-me-to-a-long-random-string-min-32-bytes
VE_SECRETS_KEY=change-me-another-long-random-string

# First-run admin (dev credentials).
VE_BOOTSTRAP_ADMIN_EMAIL=support@geniusvision.in
VE_BOOTSTRAP_ADMIN_PASSWORD=Gvd@6001

# Licensing — bundle the vendor public key; token optional in dev.
VE_LICENSE_PUBLIC_KEY_FILE=license_pub.pem
# VE_LICENSE_TOKEN_FILE=license.jwt

# Frontend origin (Next.js dev)
VE_CORS_ORIGINS=["http://localhost:3000"]

# Storage — local by default; switch to RustFS(S3) with VE_STORAGE_BACKEND=s3 + VE_S3_*
VE_STORAGE_BACKEND=local
VE_STORAGE_LOCAL_DIR=./data/storage

# RustFS server creds (consumed by the rustfs image)
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
